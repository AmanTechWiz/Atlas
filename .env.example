# Gemini API Configuration
# Copy this file to .env and fill in your real key.
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini LLM model used for Orchestrator / Analyst / Verifier
GEMINI_MODEL=gemini-3.1-flash-lite

# Gemini embedding model used for ChromaDB ingestion + retrieval
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Embedding backend: 'ollama' (local, no API key) or 'gemini' (API)
EMBEDDING_BACKEND=ollama

# Ollama config (only used when EMBEDDING_BACKEND=ollama)
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
